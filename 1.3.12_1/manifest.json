{
   "manifest_version": 3,
   "author": "Kevin King",
   "name": "Ears: Bass Boost, EQ Any Audio!",
   "short_name": "Ears",
   "version": "1.3.12",
   "description": "EQ any audio you find on the web, live! Crank the bass, dim the highs, up the vocals: all with Ears!",
   "icons": {
      "16": "ears16.png",
      "32": "ears32.png",
      "48": "ears48.png",
      "64": "ears64.png",
      "128": "ears128.png"
   },
   "action": {
      "default_icon": "ears128.png",
      "default_popup": "popup.html"
   },
   "background": {
      "service_worker": "bg.js"
   },
   "permissions": [ "activeTab", "tabCapture", "tabs", "storage", "offscreen", "downloads" ],
   "content_security_policy": {
      "extension_pages": "script-src 'self'; object-src 'self'"
   },
   "key": ""
}
